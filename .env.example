############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

# Genera una contraseña segura para PostgreSQL (mínimo 16 caracteres)
POSTGRES_PASSWORD=your-super-secret-postgres-password-here

# Genera un JWT_SECRET seguro (mínimo 32 caracteres)
# Puedes generar uno con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Genera una ANON_KEY (puedes usar el mismo JWT_SECRET)
ANON_KEY=your-anon-key-here

# Genera una SERVICE_ROLE_KEY (puedes usar el mismo JWT_SECRET)
SERVICE_ROLE_KEY=your-service-role-key-here

# Genera un SECRET_KEY_BASE para Realtime (mínimo 64 caracteres)
# Puedes generar uno con: openssl rand -base64 64
SECRET_KEY_BASE=your-super-secret-secret-key-base-with-at-least-64-characters-long

# API Key para Logflare (genera uno aleatorio)
LOGFLARE_API_KEY=your-logflare-api-key-here

############
# Dominios y URLs
############

# URL externa de la API (cambia por tu dominio)
API_EXTERNAL_URL=https://api.tudominio.com

# URL del sitio (cambia por tu dominio)
SITE_URL=https://app.tudominio.com

# Dominio para Kong (API Gateway)
KONG_HOST=api.tudominio.com

# Dominio para Studio (Dashboard)
STUDIO_HOST=studio.tudominio.com

# URLs adicionales permitidas para redirección (separadas por comas)
ADDITIONAL_REDIRECT_URLS=

############
# Configuración de Studio
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# Credenciales para el dashboard (cambia estas credenciales)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-secure-dashboard-password

############
# Auth (GoTrue)
############

# Habilitar/Deshabilitar registro de usuarios
DISABLE_SIGNUP=false

# Expiración del JWT en segundos (3600 = 1 hora)
JWT_EXPIRY=3600

# Habilitar confirmación automática por email
ENABLE_EMAIL_AUTOCONFIRM=false

# Habilitar registro por email
ENABLE_EMAIL_SIGNUP=true

# Habilitar registro por teléfono
ENABLE_PHONE_SIGNUP=false

# Confirmación automática por teléfono
ENABLE_PHONE_AUTOCONFIRM=false

############
# SMTP / Email
############

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_SENDER_NAME=Supabase Auth

# Asuntos de emails
MAILER_SUBJECTS_CONFIRMATION=Confirm Your Signup
MAILER_SUBJECTS_INVITE=You have been invited
MAILER_SUBJECTS_RECOVERY=Reset Your Password
MAILER_SUBJECTS_EMAIL_CHANGE=Confirm Email Change

############
