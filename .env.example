############
# Storage (S3)
############

# Configuración de almacenamiento S3 (puedes usar MinIO, AWS S3, etc.)
STORAGE_S3_BUCKET=supabase-storage
STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
STORAGE_S3_ACCESS_KEY_ID=your-s3-access-key
STORAGE_S3_SECRET_ACCESS_KEY=your-s3-secret-key
STORAGE_S3_REGION=us-east-1

############
# PostgREST
############

# Esquemas disponibles en PostgREST (separados por comas)
PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# OpenAI (Opcional - para AI features en Studio)
############

OPENAI_API_KEY=
