{
  "version": "4.0.0",
  "name": "Supabase",
  "description": "Supabase self-hosted on Coolify v4",
  "type": "docker-compose",
  "compose_file": "docker-compose.yml",
  "min_coolify_version": "4.0.0-beta.400",
  "services": {
    "kong": {
      "name": "Kong API Gateway",
      "description": "API Gateway para Supabase",
      "ports": ["8000"],
      "domains": ["${KONG_HOST}"],
      "healthcheck": {
        "path": "/health",
        "port": 8000
      }
    },
    "studio": {
      "name": "Supabase Studio",
      "description": "Dashboard administrativo de Supabase",
      "ports": ["3000"],
      "domains": ["${STUDIO_HOST}"],
      "healthcheck": {
        "path": "/api/health",
        "port": 3000
      }
    },
    "db": {
      "name": "PostgreSQL",
      "description": "Base de datos PostgreSQL con extensiones de Supabase",
      "ports": ["5432"],
      "volumes": ["db-data"]
    }
  },
  "environment_variables": {
    "required": [
      "POSTGRES_PASSWORD",
      "JWT_SECRET",
      "ANON_KEY",
      "SERVICE_ROLE_KEY",
      "SECRET_KEY_BASE",
      "LOGFLARE_API_KEY",
      "API_EXTERNAL_URL",
      "SITE_URL",
      "KONG_HOST",
      "STUDIO_HOST"
    ],
    "optional": [
      "SMTP_HOST",
      "SMTP_PORT",
      "SMTP_USER",
      "SMTP_PASS",
      "STORAGE_S3_BUCKET",
      "STORAGE_S3_ENDPOINT",
      "STORAGE_S3_ACCESS_KEY_ID",
      "STORAGE_S3_SECRET_ACCESS_KEY",
      "STORAGE_S3_REGION"
    ]
  }
}
